FROM python:3

COPY ./django_script.sh /
# COPY ./urls.py /
# COPY ./vieews.py /


WORKDIR /usr/src/app

COPY /django_script.sh /usr/src/app

RUN pip install --no-cache-dir Django

# RUN django-admin startproject backend .
EXPOSE 8000

RUN chmod +x ./django_script.sh

RUN ./django_script.sh

COPY /urls.py /usr/src/app/hello/
COPY /settings.py /usr/src/app/backend/settings.py
COPY /uurls.py /usr/src/app/backend/urls.py
COPY /vieews.py /usr/src/app/hello/views.py
COPY /index.html /usr/src/app/hello/templates/hello
COPY /greet.html /usr/src/app/hello/templates/hello


CMD ["python", "manage.py", "runserver", "0.0.0.0:8000"]